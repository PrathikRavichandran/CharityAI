# ============================================================
# CharityAI — Environment Variables Template
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ============================================================

# --- PostgreSQL (AWS RDS) ---
DB_HOST=charityai-db.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=pg-charityai
DATABASE_URL=postgresql+asyncpg://postgres:pg-charityai@charityai-db.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com:5432/postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_PHI3=phi3
OLLAMA_MODEL_MISTRAL=mistral
OLLAMA_MODEL_LLAMA3=llama3

# --- Gmail API ---
GMAIL_CREDENTIALS_PATH=auth/gmail_oauth.json
GMAIL_TOKEN_PATH=auth/gmail_token.json
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.modify
GMAIL_POLL_INTERVAL_SECONDS=300

# --- Google Calendar API ---
GCAL_CREDENTIALS_PATH=auth/gcalendar_oauth.json
GCAL_TOKEN_PATH=auth/gcalendar_token.json
GCAL_SCOPES=https://www.googleapis.com/auth/calendar
# Executive's calendar ID (usually their email address)
GCAL_CALENDAR_ID=primary
# Scheduling window (days from today)
GCAL_SLOT_MIN_DAYS=14
GCAL_SLOT_MAX_DAYS=28
# Appointment duration (minutes)
GCAL_APPT_DURATION_MIN=30
# Slot search hours (CST, 24hr format)
GCAL_SLOT_START_HOUR=13
GCAL_SLOT_END_HOUR=17

# --- Slack ---
SLACK_APP_ID=A0AGDERLTHC
SLACK_CLIENT_ID=10544109340487.10557501707590
SLACK_CLIENT_SECRET=cd23af0317cbd64382b340ce1cbb9332
SLACK_SIGNING_SECRET=69d687d13eef6dcc937b0e7e5f309f8c
SLACK_VERIFICATION_TOKEN=6fTP46qlAbnNxWkr8A7K4tfe
# Bot token (xoxb-...) — from Slack App dashboard after install
SLACK_BOT_TOKEN=xoxb-YOUR-BOT-TOKEN-HERE
# PA's Slack User ID (e.g. U01234567)
PA_SLACK_USER_ID=U0YOUR_PA_ID

# --- IRS Tax-Exempt Search API ---
IRS_EXEMPT_API_URL=https://efts.irs.gov/LATEST/search-index
IRS_EXEMPT_PAGE_SIZE=5

# --- Web Search (Optional — for verification fallback) ---
# Provide EITHER SerpAPI key OR leave blank for DuckDuckGo (no key needed)
SERPAPI_KEY=

# --- Candid API (Future — currently disabled / stub mode) ---
CANDID_API_KEY=
CANDID_BASE_URL=https://api.candid.org/premier/v3
CANDID_MODE=stub   # stub | live  (switch to 'live' when API key is obtained)

# --- Orchestrator ---
ORCHESTRATOR_URL=http://localhost:8000
ORCHESTRATOR_PORT=8000

# --- Agent Ports (local dev) ---
EMAIL_WATCHER_PORT=8001
DEDUP_GUARD_PORT=8002
CHARITY_VERIFIER_PORT=8003
ELIGIBILITY_AGENT_PORT=8004
PRIORITIZER_PORT=8005
CALENDAR_AGENT_PORT=8006
PA_NOTIFICATION_PORT=8007
EMAIL_COMPOSER_PORT=8008
RSVP_MONITOR_PORT=8009

# --- Timezone ---
TIMEZONE=America/Chicago

# --- Pipeline Rules ---
ELIGIBILITY_WINDOW_DAYS=90
PA_TIMEOUT_HOURS=24
RSVP_TIMEOUT_HOURS=24
QUEUE_BUMP_SCORE=5
QUEUE_BUMP_CAP=25
QUEUE_BUMP_INTERVAL_DAYS=7

# --- Environment ---
ENV=development     # development | production
LOG_LEVEL=INFO
