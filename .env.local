# ============================================================================
# CharityAI — .env.local (Local Development — uses Docker Postgres + Redis)
# Copy this to .env when developing locally instead of RDS:
#   cp .env.local .env
# ============================================================================

# --- PostgreSQL (Local Docker — run: docker compose -f infra/docker-compose.yml up -d) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=pg-charityai
DATABASE_URL=postgresql+asyncpg://postgres:pg-charityai@localhost:5432/postgres

# --- Redis (Local Docker) ---
REDIS_URL=redis://localhost:6379/0

# --- Ollama (Local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_PHI3=phi3
OLLAMA_MODEL_MISTRAL=mistral
OLLAMA_MODEL_LLAMA3=llama3

# --- Agent URLs (all local) ---
ORCHESTRATOR_URL=http://localhost:8000
DEDUP_GUARD_URL=http://localhost:8002
CHARITY_VERIFIER_URL=http://localhost:8003
ELIGIBILITY_AGENT_URL=http://localhost:8004
PRIORITIZER_URL=http://localhost:8005
CALENDAR_AGENT_URL=http://localhost:8006
PA_NOTIFICATION_URL=http://localhost:8007
EMAIL_COMPOSER_URL=http://localhost:8008
RSVP_MONITOR_URL=http://localhost:8009

# --- Gmail OAuth ---
GMAIL_TOKEN_PATH=auth/gmail_token.json
GMAIL_OAUTH_PATH=auth/gmail_oauth.json
GCAL_TOKEN_PATH=auth/gcalendar_token.json

# --- GCal Settings ---
GCAL_CALENDAR_ID=primary
GCAL_SLOT_MIN_DAYS=14
GCAL_SLOT_MAX_DAYS=28
GCAL_APPT_DURATION_MIN=30
GCAL_SLOT_START_HOUR=13
GCAL_SLOT_END_HOUR=17

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-10544109340487-10553261841651-rhsxeKKnENafdg1FoCmcZJS4
SLACK_SIGNING_SECRET=69d687d13eef6dcc937b0e7e5f309f8c
PA_SLACK_USER_ID=U0AG94W306P

# --- IRS Exempt API ---
IRS_EXEMPT_API_URL=https://efts.irs.gov/LATEST/search-index

# --- Candid (stub mode) ---
CANDID_MODE=stub
CANDID_API_KEY=

# --- Email Polling ---
